# Force feedback submit error UI (?feedback_fail=1 in URL does the same)
# NEXT_PUBLIC_FEEDBACK_DEBUG_FAIL=true

# Show copyable landing device stage debug panel (?landing_stage_debug=1 does the same)
# NEXT_PUBLIC_LANDING_STAGE_DEBUG=true

# Tweakpane editor for device mockup layout (?landing_stage_tuner=1 does the same)
# NEXT_PUBLIC_LANDING_STAGE_TUNER=true

# Feedback provider (optional — auto-detects per app from config.ts web3formsAccessKey)
# Values: web3forms | formspree | supabase | http | console | unconfigured
# NEXT_PUBLIC_FEEDBACK_PROVIDER=web3forms

# Override Web3Forms key for all apps (optional; keys are set per app in config.ts)
# NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# --- Formspree (later) ---
# NEXT_PUBLIC_FORMSPREE_FORM_ID=xyzabcde

# --- Supabase (later) ---
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# NEXT_PUBLIC_SUPABASE_FEEDBACK_TABLE=feedback

# --- Generic webhook (later) ---
# NEXT_PUBLIC_FEEDBACK_ENDPOINT=https://your-endpoint.example/feedback
