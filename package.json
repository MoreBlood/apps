{
	"name": "ak-apps-web",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter hub dev",
		"dev:rawclinic": "pnpm --filter rawclinic dev",
		"build": "pnpm --filter hub build",
		"build:rawclinic": "pnpm --filter rawclinic build",
		"generate:images": "pnpm --filter @ak-apps/shared generate:images",
		"generate:mockups": "node packages/shared/scripts/svg-mockup-to-tsx.mjs",
		"generate:compare-blur": "pnpm --filter @ak-apps/shared generate:images",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "pnpm --filter hub exec next lint",
		"lint:staged": "lint-staged",
		"lint:staged:fix": "lint-staged",
		"lighthouse:audit": "node packages/shared/scripts/lighthouse-audit.mjs",
		"lighthouse:baseline": "node packages/shared/scripts/lighthouse-baseline.mjs",
		"lighthouse:compare": "node packages/shared/scripts/lighthouse-compare.mjs",
		"lighthouse:migrate-scores": "node packages/shared/scripts/lighthouse-migrate-scores.mjs",
		"typecheck": "pnpm -r typecheck",
		"check": "pnpm typecheck && npx @biomejs/biome check .",
		"precommit": "node packages/shared/scripts/pre-commit.mjs",
		"prepare": "husky",
		"deploy": "pnpm build && gh-pages -d apps/hub/out"
	},
	"dependencies": {
		"@radix-ui/react-icons": "^1.3.2",
		"@radix-ui/react-menubar": "^1.1.16",
		"@radix-ui/themes": "^3.3.0",
		"clsx": "^2.1.1",
		"framer-motion": "^12.40.0",
		"lenis": "^1.3.23",
		"modern-normalize": "^3.0.1",
		"next": "^16.0.4",
		"next-themes": "^0.4.6",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tweakpane": "^4.0.5",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.0",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitest/coverage-v8": "^4.0.18",
		"gh-pages": "^6.3.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.6",
		"sass": "^1.94.2",
		"sharp": "^0.34.5",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"lint-staged": {
		"*.{js,mjs,cjs,ts,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
	}
}
